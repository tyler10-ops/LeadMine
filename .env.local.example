NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANTHROPIC_API_KEY=sk-ant-your-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get from Stripe Dashboard > Webhooks (after registering your endpoint)
# Local dev: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# Create products in Stripe Dashboard, then copy the Price IDs here
# Products: Miner, Operator, Brokerage — each with monthly + annual prices
STRIPE_PRICE_MINER_MONTHLY=price_...
STRIPE_PRICE_MINER_ANNUAL=price_...
STRIPE_PRICE_OPERATOR_MONTHLY=price_...
STRIPE_PRICE_OPERATOR_ANNUAL=price_...
STRIPE_PRICE_BROKERAGE_MONTHLY=price_...
STRIPE_PRICE_BROKERAGE_ANNUAL=price_...

# ── Email Notifications (Resend) ───────────────────────────────────────────────
# Sign up at https://resend.com — free tier sends 3,000 emails/month
RESEND_API_KEY=re_...
NOTIFICATION_FROM_EMAIL=briefs@yourdomain.com

# ── Web Push Notifications (VAPID) ────────────────────────────────────────────
# Generate your VAPID keypair once:
#   node -e "const wp = require('web-push'); const k = wp.generateVAPIDKeys(); console.log(JSON.stringify(k, null, 2))"
# Paste the output below — NEXT_PUBLIC_ key goes in the browser, private stays server-only
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ── Mining Queue (BullMQ + Upstash Redis) ─────────────────────────────────────
# Required for the lead mining pipeline. Get from https://console.upstash.com
# Create a Redis database → Details tab → copy "Redis URL" (format: rediss://default:TOKEN@host:port)
# Worker process must also be running: npx tsx scripts/worker.ts
UPSTASH_REDIS_URL=rediss://default:TOKEN@your-db.upstash.io:6379

# ── Google Places API (Lead Scraping) ─────────────────────────────────────────
# Required for the Google Places scraper used by the mining worker
# Enable "Places API (New)" in Google Cloud Console
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ── ATTOM Property Data API ────────────────────────────────────────────────────
# Commercial property data: owner info, AVM, sales history, absentee-owner flags
# Sign up at https://developer.attomdata.com — replaces broken county open data URLs
# When set, ALL county mining uses ATTOM instead of open Socrata portals
# Covers all 50 states via FIPS code — no more per-county URL maintenance
ATTOM_API_KEY=your-attom-api-key         # Re-enable when upgrading to paid ATTOM plan
RENTCAST_API_KEY=your-rentcast-api-key   # Primary property data source — rentcast.io

# ── Vapi.ai (AI Voice Calling) ────────────────────────────────────────────────
# Sign up at https://app.vapi.ai
# 1. Get your API key from dashboard → Account → API Keys
# 2. Buy a phone number (or import Twilio): dashboard → Phone Numbers → Buy
# 3. Copy the Phone Number ID from the phone number detail page
VAPI_API_KEY=your-vapi-api-key
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id

# ── Twilio SMS (A2P 10DLC) ───────────────────────────────────────────────────
# Console: https://console.twilio.com
# 1. Account SID + Auth Token from Console → Account → API keys & tokens
# 2. After A2P 10DLC Brand + Campaign approval, create a Messaging Service
#    and attach your registered phone number to it. Use the Messaging
#    Service SID (MGxxxx...) — NOT the raw From number — so carriers
#    attribute messages to your approved Campaign.
# 3. Configure inbound webhook on the Messaging Service:
#    POST https://leadmineapp.com/api/outreach/sms/inbound
#    (handles STOP / HELP / replies — required for TCPA compliance)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional fallback if you don't have a Messaging Service yet (NOT A2P-compliant for production):
# TWILIO_FROM_NUMBER=+15555551234

# ── Cron Security ──────────────────────────────────────────────────────────────
# Set a random secret to protect /api/cron/daily-brief from public access
# In Vercel: add this as an env var — Vercel Cron passes it automatically
CRON_SECRET=your-random-secret-here
